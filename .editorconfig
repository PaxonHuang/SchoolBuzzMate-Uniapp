# EditorConfig - 跨编辑器/跨 OS 统一格式
# https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Windows-only 脚本保留 CRLF (与 .gitattributes 对齐)
[*.{ps1,psm1,psd1,bat,cmd}]
end_of_line = crlf

# Markdown 保留行尾空格 (硬换行语义)
[*.md]
trim_trailing_whitespace = false

# 锁文件不强制
[pnpm-lock.yaml]
insert_final_newline = false
