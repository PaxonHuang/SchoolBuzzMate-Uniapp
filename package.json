{
  "name": "schoolbuzz-mate",
  "type": "module",
  "version": "0.1.0",
  "packageManager": "pnpm@10.10.0",
  "description": "校趣闪搭 - 校园社交交易平台",
  "author": "PaxonHuang",
  "license": "MIT",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev:h5": "cross-env NODE_OPTIONS=--no-experimental-strip-types uni",
    "dev:h5:test": "cross-env NODE_OPTIONS=--no-experimental-strip-types uni --mode test",
    "dev:h5:prod": "cross-env NODE_OPTIONS=--no-experimental-strip-types uni --mode production",
    "dev:mp-weixin": "cross-env NODE_OPTIONS=--no-experimental-strip-types uni -p mp-weixin",
    "dev:mp-weixin:test": "cross-env NODE_OPTIONS=--no-experimental-strip-types uni -p mp-weixin --mode test",
    "dev:mp-weixin:prod": "cross-env NODE_OPTIONS=--no-experimental-strip-types uni -p mp-weixin --mode production",
    "build:h5": "cross-env NODE_OPTIONS=--no-experimental-strip-types uni build",
    "build:h5:prod": "cross-env NODE_OPTIONS=--no-experimental-strip-types uni build --mode production",
    "build:mp-weixin": "cross-env NODE_OPTIONS=--no-experimental-strip-types uni build -p mp-weixin && node scripts/fix-mp-weixin-appid.mjs && node scripts/inject-unicloud-init.mjs",
    "build:mp-weixin:prod": "cross-env NODE_OPTIONS=--no-experimental-strip-types uni build -p mp-weixin --mode production && node scripts/fix-mp-weixin-appid.mjs && node scripts/inject-unicloud-init.mjs dist/build/mp-weixin",
    "watch:unicloud": "node scripts/unicloud-init-watcher.mjs",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "deploy:cloud": "powershell -ExecutionPolicy Bypass -File scripts/deploy-cloud.ps1",
    "deploy:cloud:order": "powershell -ExecutionPolicy Bypass -File scripts/deploy-cloud.ps1 -Functions order-co,favorites-co",
    "e2e:check": "powershell -ExecutionPolicy Bypass -File scripts/e2e-check.ps1",
    "e2e:full": "powershell -ExecutionPolicy Bypass -File scripts/e2e-check.ps1 -TestFlow",
    "dev:sh": "bash scripts/dev.sh mp-weixin",
    "deploy:cloud:sh": "bash scripts/deploy-cloud.sh",
    "deploy:cloud:sh:dry": "bash scripts/deploy-cloud.sh --dry-run",
    "e2e:check:sh": "bash scripts/e2e-check.sh",
    "e2e:check:sh:nodep": "bash scripts/e2e-check.sh --no-deploy",
    "e2e:full:sh": "bash scripts/e2e-check.sh --test-flow",
    "prepare": "husky"
  },
  "dependencies": {
    "@dcloudio/uni-app": "3.0.0-4070620250821001",
    "@dcloudio/uni-app-plus": "3.0.0-4070620250821001",
    "@dcloudio/uni-components": "3.0.0-4070620250821001",
    "@dcloudio/uni-h5": "3.0.0-4070620250821001",
    "@dcloudio/uni-mp-weixin": "3.0.0-4070620250821001",
    "dayjs": "1.11.10",
    "pinia": "2.0.36",
    "pinia-plugin-persistedstate": "3.2.1",
    "vue": "^3.4.21",
    "wot-design-uni": "^1.13.0",
    "z-paging": "2.8.7"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@dcloudio/types": "^3.4.8",
    "@dcloudio/uni-automator": "3.0.0-4070620250821001",
    "@dcloudio/uni-cli-shared": "3.0.0-4070620250821001",
    "@dcloudio/vite-plugin-uni": "3.0.0-4070620250821001",
    "@esbuild/win32-x64": "0.20.2",
    "@iconify-json/carbon": "^1.2.4",
    "@rollup/rollup-win32-x64-msvc": "4.61.1",
    "@types/node": "^20.17.9",
    "@uni-helper/eslint-config": "0.5.0",
    "@uni-helper/plugin-uni": "^0.1.0",
    "@uni-helper/uni-env": "0.1.8",
    "@uni-helper/unocss-preset-uni": "0.2.11",
    "@uni-helper/vite-plugin-uni-components": "0.2.3",
    "@uni-helper/vite-plugin-uni-layouts": "0.1.11",
    "@uni-helper/vite-plugin-uni-manifest": "0.2.11",
    "@uni-helper/vite-plugin-uni-pages": "0.3.19",
    "@uni-helper/vite-plugin-uni-platform": "^0.1.2",
    "@uni-ku/bundle-optimizer": "^2.2.0",
    "@uni-ku/root": "^1.4.1",
    "@unocss/preset-icons": "66.0.0",
    "@unocss/preset-legacy-compat": "66.0.0",
    "@vue/tsconfig": "^0.1.3",
    "cross-env": "^10.1.0",
    "eslint": "^9.31.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "miniprogram-api-typings": "^4.1.0",
    "sass": "1.77.8",
    "typescript": "~5.8.0",
    "unocss": "66.0.0",
    "unplugin-auto-import": "^20.0.0",
    "vite": "5.2.8",
    "vue-tsc": "^3.0.6"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
